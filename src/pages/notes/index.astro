---
import { getCollection, render } from "astro:content";
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pagination from "@/components/Pagination.astro";
import NoteItem from "@/components/notes/NoteItem.astro";

const notes = await getCollection("notes");
const sortedNotes = notes.sort(
  (a, b) =>
    Date.parse(b.data.published.toString()) -
    Date.parse(a.data.published.toString()),
);

const pageSize = 20;
const firstPageNotes = sortedNotes.slice(0, pageSize);
const totalPages = Math.ceil(sortedNotes.length / pageSize);

const page = {
  currentPage: 1,
  lastPage: totalPages,
  start: 0,
  end: Math.min(pageSize, sortedNotes.length) - 1,
  total: sortedNotes.length,
  data: firstPageNotes,
  size: pageSize,
  url: {
    current: "/notes",
    next: totalPages > 1 ? "/notes/2" : undefined,
    prev: undefined,
    first: "/notes",
    last: `/notes/${totalPages}`,
  },
} satisfies Page<CollectionEntry<"notes">>;

const renderedNotes = await Promise.all(
  firstPageNotes.map(async (note) => {
    const { Content } = await render(note);
    return { note, Content };
  }),
);
---

<BaseLayout title="Notes">
  <header class="container">
    <h1
      class="text-3xl font-medium tracking-tight text-pretty [text-box-trim:trim-start]"
    >
      Notes
      <span class="text-muted-foreground"
        >on engineering, developer experience, design systems, and
        accessibility.</span
      >
    </h1>
  </header>

  <section class="container mt-20">
    <ul>
      {renderedNotes.map(({ note, Content }) => <NoteItem {note} {Content} />)}
    </ul>

    <Pagination page={page} class="mt-20" collection="notes" />
  </section>
</BaseLayout>
