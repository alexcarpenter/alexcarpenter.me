---
import type { HTMLTag, Polymorphic } from "astro/types";
import { cva, type VariantProps } from "class-variance-authority";

const buttonVariants = cva(
  "inline-flex shrink-0 items-center justify-center gap-2 rounded-full whitespace-nowrap transition-all disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4",
  {
    variants: {
      variant: {
        default:
          "[&:is(a,button)]:hover:bg-separator border-separator border bg-white dark:bg-neutral-900",
        ghost:
          "[&:is(a,button)]:hover:bg-separator [&:is(a,button)]:hover:border-separator border-transparent border text-muted-foreground [&:is(a,button)]:hover:text-foreground",
      },
      size: {
        default: "h-8 px-4",
        icon: "size-8",
      },
    },
    defaultVariants: {
      variant: "default",
      size: "default",
    },
  },
);

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> &
  VariantProps<typeof buttonVariants>;

const {
  as: Tag = "button",
  variant,
  size,
  class: className,
  ...props
} = Astro.props;
---

<Tag {...props} class={buttonVariants({ variant, size, className })}
  ><slot /></Tag
>
