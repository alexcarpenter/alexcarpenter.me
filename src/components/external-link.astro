---
import { Icon } from "astro-icon/components";
const { href, text, class: className } = Astro.props;
---

{/* prettier-ignore */}
<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={["relative inline-block pr-3.5", className]}
  >{text}<Icon
    name="arrow-up-right"
    aria-hidden="true"
    class="absolute ml-1 inline h-5 w-2.5 flex-none"
  /></a
>
